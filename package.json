{
  "name": "scratch-to-python-ide",
  "version": "0.1.0",
  "description": "Teach kids to transition from Scratch blocks to Python",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
